---
const title = "Telur Asin Rose | Telur Asin Premium Gurih, Asin, Berkualitas";
const description = "Premium quality salted eggs with traditional curing methods";
---

<html class="scroll-smooth" lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{title}</title>
		<script is:inline src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
		<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
	
		<script is:inline id="tailwind-config">
			tailwind.config = {
				darkMode: "class",
				theme: {
					extend: {
						"colors": {
							"background": "#faf9f5",
							"surface-container-highest": "#e3e2de",
							"primary-fixed": "#ceeac5",
							"secondary-container": "#fecddd",
							"error": "#ba1a1a",
							"outline": "#747970",
							"on-primary": "#ffffff",
							"primary-fixed-dim": "#b3ceab",
							"inverse-on-surface": "#f2f1ec",
							"surface-tint": "#4c6548",
							"surface-container-low": "#f5f4ef",
							"on-tertiary-container": "#66404d",
							"tertiary-fixed-dim": "#ecb9c9",
							"tertiary": "#7b5361",
							"primary-container": "#a8c3a0",
							"on-primary-fixed": "#0a2009",
							"on-surface": "#1b1c19",
							"on-primary-fixed-variant": "#354d31",
							"surface-container-high": "#e9e8e4",
							"surface-variant": "#e3e2de",
							"on-tertiary-fixed": "#30121e",
							"error-container": "#ffdad6",
							"inverse-surface": "#30312e",
							"on-secondary-container": "#7a5562",
							"on-primary-container": "#3a5135",
							"inverse-primary": "#b3ceab",
							"surface": "#faf9f5",
							"surface-container-lowest": "#ffffff",
							"on-secondary-fixed": "#2e131e",
							"primary": "#4c6548",
							"on-background": "#1b1c19",
							"on-tertiary": "#ffffff",
							"on-error": "#ffffff",
							"outline-variant": "#c3c8be",
							"surface-bright": "#faf9f5",
							"on-tertiary-fixed-variant": "#613c49",
							"tertiary-container": "#e0aebe",
							"tertiary-fixed": "#ffd9e4",
							"surface-container": "#efeee9",
							"on-secondary": "#ffffff",
							"surface-dim": "#dbdad6",
							"on-surface-variant": "#434841",
							"on-error-container": "#93000a",
							"secondary-fixed-dim": "#e9baca",
							"secondary-fixed": "#ffd9e5",
							"secondary": "#795462",
							"on-secondary-fixed-variant": "#5f3d4a"
						},
						"borderRadius": {
							"DEFAULT": "0.25rem",
							"lg": "0.5rem",
							"xl": "0.75rem",
							"full": "9999px"
						},
						"spacing": {
							"container-max": "1200px",
							"section-gap": "80px",
							"margin-desktop": "40px",
							"unit": "4px",
							"margin-mobile": "16px",
							"gutter": "24px"
						},
						"fontFamily": {
							"headline-lg-mobile": ["Poppins"],
							"display-lg": ["Poppins"],
							"body-lg": ["Inter"],
							"headline-lg": ["Poppins"],
							"label-md": ["Inter"],
							"label-sm": ["Inter"],
							"body-md": ["Inter"],
							"headline-md": ["Poppins"]
						},
						"fontSize": {
							"headline-lg-mobile": ["28px", {"lineHeight": "1.3", "fontWeight": "600"}],
							"display-lg": ["48px", {"lineHeight": "1.2", "letterSpacing": "-0.02em", "fontWeight": "600"}],
							"body-lg": ["18px", {"lineHeight": "1.6", "fontWeight": "400"}],
							"headline-lg": ["32px", {"lineHeight": "1.3", "fontWeight": "600"}],
							"label-md": ["14px", {"lineHeight": "1.4", "letterSpacing": "0.01em", "fontWeight": "500"}],
							"label-sm": ["12px", {"lineHeight": "1.2", "fontWeight": "600"}],
							"body-md": ["16px", {"lineHeight": "1.6", "fontWeight": "400"}],
							"headline-md": ["24px", {"lineHeight": "1.4", "fontWeight": "500"}]
						}
					},
				},
			}
		</script>
		<style>
			.material-symbols-outlined {
				font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
			}
			.frosted-glass {
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
			}
			.hero-gradient {
				background: linear-gradient(rgba(250, 249, 245, 0.4), rgba(250, 249, 245, 0.4));
			}
			.product-card-hover:hover {
				transform: translateY(-8px);
				box-shadow: 0 20px 40px -10px rgba(76, 101, 72, 0.1);
			}
			.transition-soft {
				transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
			}
		</style>
	</head>
	<body class="bg-background text-on-background font-body-md text-body-md overflow-x-hidden">
		<!-- Top Navigation Bar -->
		<nav class="fixed top-0 w-full z-50 bg-surface/90 frosted-glass shadow-sm">
			<div class="flex justify-between items-center px-margin-desktop py-4 max-w-container-max mx-auto">
				<div class="flex items-center gap-4">
					<img alt="Telur Asin Rose" class="h-10 w-auto object-contain" src="/logo.png"/>
				</div>
				<div class="hidden md:flex items-center gap-8">
				<a class="font-label-md text-label-md text-primary border-b-2 border-primary pb-1" href="/">Home</a>
				<a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors duration-200" href="/products">Products</a>
				<a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors duration-200" href="/about">About</a>
				<a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors duration-200" href="/faq">FAQ</a>
				<a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors duration-200" href="/contact">Contact</a>
				</div>
				<div class="flex items-center gap-4">
					<button class="text-on-surface-variant hover:text-primary transition-colors">
						<span class="material-symbols-outlined">shopping_cart</span>
					</button>
				<a class="hidden md:block bg-primary text-on-primary px-6 py-2 rounded-lg font-label-md text-label-md font-semibold hover:opacity-90 transition-opacity" href="/cart">Buy Now</a>
				</div>
			</div>
		</nav>
		<!-- Hero Section -->
		<section class="relative min-h-screen flex items-center pt-20 overflow-hidden" id="home">
			<div class="absolute inset-0 z-0">
				<div class="w-full h-full bg-cover bg-center" data-alt="A macro photograph of premium salted eggs elegantly split open, showcasing the rich, oily, and vibrant orange yolk with a slightly grainy texture. The eggs are arranged on a rustic linen napkin atop a light wooden surface. Soft, natural sunlight streams from the side, creating long, delicate shadows. The color palette consists of warm creams, soft whites, and deep earthy greens, reflecting a high-end, artisanal boutique feel." style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuA85EO25y86mxcePzCMhrXTk5mfbYlunbPnLX5Z6R3lh4OskFANzbB3F2l9Qeh1fYFBRjpNQigJ_lexQIORAi2HSum9mWBPHPLwUYF49kROsJJ2O7fHSpZsTNfvA4Bypx-lI_x8MuQ7fZoqPMCDLb_AcYJ0uB8UFyQCLfRVlsqPMHgo1El7pJFSSzxNEfCQXoOx0DmHDemCotfwdDIIjZNexgmup3mOXSN5JONNalRY82c7_C4zFE0')"></div>
				<div class="absolute inset-0 bg-gradient-to-r from-background/80 via-background/40 to-transparent"></div>
			</div>
			<div class="relative z-10 px-margin-desktop max-w-container-max mx-auto w-full">
				<div class="max-w-xl">
					<span class="inline-block px-4 py-1 rounded-full bg-primary-fixed text-on-primary-fixed-variant font-label-sm text-label-sm mb-6 uppercase tracking-wider">Since 2026</span>
					<h1 class="font-display-lg text-display-lg text-on-surface mb-6 leading-tight">Telur Asin Premium
Gurih, Asin, Berkualitas, <span class="text-primary">Modern Elegance</span></h1>
					<p class="font-body-lg text-body-lg text-on-surface-variant mb-10 leading-relaxed">Nikmati telur asin premium yang dibuat dari telur bebek pilihan menggunakan proses tradisional yang higienis. Menghasilkan cita rasa gurih, tekstur lembut, dan kualitas terbaik untuk keluarga maupun oleh-oleh khas. of artisanal salted eggs, perfected over generations to deliver a creamy, savory delicacy for the modern palate.</p>
					<div class="flex flex-wrap gap-4">
						<a class="bg-primary text-on-primary px-8 py-4 rounded-lg font-label-md text-label-md font-bold shadow-lg hover:shadow-xl transition-all hover:-translate-y-1" href="#products">Lihat Produk</a>
						<a class="bg-secondary-container text-on-secondary-container px-8 py-4 rounded-lg font-label-md text-label-md font-bold hover:bg-opacity-80 transition-all" href="#about">Tentang Kami</a>
					</div>
				</div>
			</div>
			<!-- Floating decorative element -->
			<div class="absolute right-0 bottom-0 opacity-20 transform translate-x-1/4 translate-y-1/4 pointer-events-none">
				<span class="material-symbols-outlined text-[400px] text-primary">spa</span>
			</div>
		</section>
		<!-- Why Choose Us -->
		<section class="py-section-gap px-margin-desktop bg-surface-container-lowest">
			<div class="max-w-container-max mx-auto">
				<div class="text-center mb-16">
					<h2 class="font-headline-lg text-headline-lg text-primary mb-4">Crafted with Integrity</h2>
					<p class="max-w-2xl mx-auto text-on-surface-variant">We believe in purity and patience. Our process respects the traditional methods that ensure every egg meets our premium standards of flavor and texture.</p>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
					<div class="p-8 bg-surface border border-outline-variant rounded-xl text-center group hover:border-primary transition-colors">
						<div class="w-16 h-16 bg-primary-fixed rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform">
							<span class="material-symbols-outlined text-primary text-3xl">done_all</span>
						</div>
						<h3 class="font-headline-md text-headline-md mb-3">Selected Eggs</h3>
						<p class="text-on-surface-variant">Only the finest, locally-sourced duck eggs make it to our facility, ensuring a consistent size and rich nutrient profile.</p>
					</div>
					<div class="p-8 bg-surface border border-outline-variant rounded-xl text-center group hover:border-primary transition-colors">
						<div class="w-16 h-16 bg-tertiary-fixed rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform">
							<span class="material-symbols-outlined text-tertiary text-3xl">sanitizer</span>
						</div>
						<h3 class="font-headline-md text-headline-md mb-3">Hygienic Process</h3>
						<p class="text-on-surface-variant">Our facility maintains hospital-grade cleanliness throughout the curing and packaging stages to ensure your safety and quality.</p>
					</div>
					<div class="p-8 bg-surface border border-outline-variant rounded-xl text-center group hover:border-primary transition-colors">
						<div class="w-16 h-16 bg-secondary-fixed rounded-full flex items-center justify-center mx-auto mb-6 group-hover:scale-110 transition-transform">
							<span class="material-symbols-outlined text-secondary text-3xl">history</span>
						</div>
						<h3 class="font-headline-md text-headline-md mb-3">Traditional Method</h3>
						<p class="text-on-surface-variant">Using only natural clay and sea salt, we cure our eggs for 21 days to achieve the perfect balance of savory and creamy flavors.</p>
					</div>
				</div>
			</div>
		</section>
		<!-- Featured Products Grid -->
		<section class="py-section-gap px-margin-desktop" id="products">
			<div class="max-w-container-max mx-auto">
				<div class="flex justify-between items-end mb-12">
					<div>
						<h2 class="font-headline-lg text-headline-lg text-on-surface mb-2">Our Signature Collection</h2>
						<p class="text-on-surface-variant">Discover the perfect salted egg for your family table.</p>
					</div>
					<a class="text-primary font-label-md text-label-md font-semibold flex items-center gap-1 hover:underline" href="#">
						View All Products <span class="material-symbols-outlined text-sm">arrow_forward</span>
					</a>
				</div>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-gutter">
					<!-- Product 1: Original -->
					<div class="product-card-hover transition-soft bg-surface rounded-xl overflow-hidden border border-surface-container-highest">
						<div class="relative h-64">
							<div class="w-full h-full bg-cover bg-center" data-alt="A professional studio product shot of a single original salted egg, perfectly boiled and halved to reveal a glowing orange yolk. The egg rests on a polished white marble slab with a sprig of fresh green herbs nearby. The lighting is soft and airy, highlighting the creamy whites and the glistening yolk. Elegant minimalist aesthetic with subtle shadows." style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBL0j2QnyNavYUkjekLJZg2lxBYMOFlCqu2ccQvCSo45SkFJyP4b_Kp5dbv-TrEkurjjcx8r3hC613P4Lh6Lb0r-B3-WMLNg6H14CycGqDhXfISxA3bufx3MZPa1Vi-nm6ni6eU5304w2KDV1FGeMN8bPPWDIPSjYZrAWLxqHcUhd8T4_RGuyG5vb3m8mBRFCCJDzcXq1Q6F19b7aKWhQ0wWAA_-HHwg-9AO-phSTHzAOIld_1afko')"></div>
							<span class="absolute top-4 left-4 bg-primary text-on-primary text-[10px] uppercase font-bold px-3 py-1 rounded-full">Bestseller</span>
						</div>
						<div class="p-6">
							<h3 class="font-headline-md text-headline-md mb-1">Original Salted Egg</h3>
							<p class="text-on-surface-variant text-sm mb-4">The classic savory taste that started it all.</p>
							<div class="flex justify-between items-center">
								<span class="font-bold text-primary">Rp 4.500</span>
								<button class="bg-secondary-container p-2 rounded-full text-on-secondary-container hover:bg-tertiary-container transition-colors">
									<span class="material-symbols-outlined text-sm">add_shopping_cart</span>
								</button>
							</div>
						</div>
					</div>
					<!-- Product 2: Panggang -->
					<div class="product-card-hover transition-soft bg-surface rounded-xl overflow-hidden border border-surface-container-highest">
						<div class="relative h-64">
							<div class="w-full h-full bg-cover bg-center" data-alt="Smoked or roasted salted eggs presented in a rustic woven basket. The eggshells have a beautiful, slight brownish hue from the roasting process. One egg is cracked open to show a dense, dark orange yolk. The setting is warm and cozy with dark olive accents and soft natural lighting from a nearby window." style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCE8iFZ6Qc5CLVMcPAH7jHC3S4TxWp4P37k7bvRTj31LQOpXEIfMLgrs701qpcinoViC47Q95jtmikIt2X77F2A0Q3xc8pBuKN_gxlYmKXzgHUpvRhJ1ACAmX3GWZfkzjtS3Q_HbejJ49nlYAWN11pMTpo3ie90K6lRmG0_OWAZMv0VOOW8-XfioCfAcMTU6337zABnJggLkpweQxMSaHW7hChSL1lndm8BvkmiKN44cZ-fxWjjkUk')"></div>
							<span class="absolute top-4 left-4 bg-tertiary text-on-tertiary text-[10px] uppercase font-bold px-3 py-1 rounded-full">Smoked</span>
						</div>
						<div class="p-6">
							<h3 class="font-headline-md text-headline-md mb-1">Panggang (Smoked)</h3>
							<p class="text-on-surface-variant text-sm mb-4">Slow-roasted for an intense, smoky aroma.</p>
							<div class="flex justify-between items-center">
								<span class="font-bold text-primary">Rp 5.500</span>
								<button class="bg-secondary-container p-2 rounded-full text-on-secondary-container hover:bg-tertiary-container transition-colors">
									<span class="material-symbols-outlined text-sm">add_shopping_cart</span>
								</button>
							</div>
						</div>
					</div>
					<!-- Product 3: Isi 10 -->
					<div class="product-card-hover transition-soft bg-surface rounded-xl overflow-hidden border border-surface-container-highest">
						<div class="relative h-64">
							<div class="w-full h-full bg-cover bg-center" data-alt="A clean, modern cardboard egg carton containing ten perfectly uniform salted eggs. The carton features a minimalist green and white label with the Rose logo. The arrangement is symmetrical and photographed from a top-down perspective on a light beige background. High-key lighting, professional commercial food photography style." style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAUK18x-KHY7T61ziP6r4LfMG7KFHUk5WrnxQCCHyG2xwqMxMObg0UTv5O_Q0dxFraxN1WFNk3FOE0HZGfLyPbUqrB_U3YIpUe23nDtysyalYCbbXkx4BHhReC6w58m8lu2x0Rs-tm0oefYbFpAMfeG3pNEDkSPoAj90QDkP8FNDA9PFCZ2HX_sDXCzyHTZP7ci3EZHT26XDbIcfdEIoqrF1skmh98wN3OZoIDVVhZI9HBcZxfI3dc')"></div>
