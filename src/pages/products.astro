<script>
        // Micro-interactions
        document.querySelectorAll('.product-card').forEach(card => {
            card.addEventListener('mouseenter', () => {
                // Potential for adding JS driven micro-animations if needed
            });
        });

        // Simple cart counter mock logic
        let count = 2;
        document.querySelectorAll('button').forEach(btn => {
            if (btn.innerText.includes('Add to Cart')) {
                btn.addEventListener('click', () => {
                    count++;
                    const badge = document.querySelector('.absolute.top-0.right-0');
                    if (badge) {
                        badge.innerText = count;
                        badge.classList.add('scale-125');
                        setTimeout(() => badge.classList.remove('scale-125'), 200);
                    }
                    
                    // Simple "Added" visual feedback
                    const originalContent = btn.innerHTML;
                    btn.innerHTML = `<span class="material-symbols-outlined text-[18px]">check_circle</span> Added!`;
                    btn.classList.replace('bg-secondary-container', 'bg-primary-fixed');
                    setTimeout(() => {
                        btn.innerHTML = originalContent;
                        btn.classList.replace('bg-primary-fixed', 'bg-secondary-container');
                    }, 2000);
                });
            }
        });
    </script>