---
const title = "Contact Us - Telur Asin Rose";
const description = "Get in touch with us for orders, inquiries, or to learn more about our traditional salted eggs";
---

<html class="light" lang="en">
	<head>
		<meta charset="utf-8"/>
		<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{title}</title>
		<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
		<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
		<script id="tailwind-config">
			tailwind.config = {
				darkMode: "class",
				theme: {
					extend: {
						"colors": {
							"background": "#faf9f5",
							"surface-container-highest": "#e3e2de",
							"primary-fixed": "#ceeac5",
							"secondary-container": "#fecddd",
							"error": "#ba1a1a",
							"outline": "#747970",
							"on-primary": "#ffffff",
							"primary-fixed-dim": "#b3ceab",
							"inverse-on-surface": "#f2f1ec",
							"surface-tint": "#4c6548",
							"surface-container-low": "#f5f4ef",
							"on-tertiary-container": "#66404d",
							"tertiary-fixed-dim": "#ecb9c9",
							"tertiary": "#7b5361",
							"primary-container": "#a8c3a0",
							"on-primary-fixed": "#0a2009",
							"on-surface": "#1b1c19",
							"on-primary-fixed-variant": "#354d31",
							"surface-container-high": "#e9e8e4",
							"surface-variant": "#e3e2de",
							"on-tertiary-fixed": "#30121e",
							"error-container": "#ffdad6",
							"inverse-surface": "#30312e",
							"on-secondary-container": "#7a5562",
							"on-primary-container": "#3a5135",
							"inverse-primary": "#b3ceab",
							"surface": "#faf9f5",
							"surface-container-lowest": "#ffffff",
							"on-secondary-fixed": "#2e131e",
							"primary": "#4c6548",
							"on-background": "#1b1c19",
							"on-tertiary": "#ffffff",
							"on-error": "#ffffff",
							"outline-variant": "#c3c8be",
							"surface-bright": "#faf9f5",
							"on-tertiary-fixed-variant": "#613c49",
							"tertiary-container": "#e0aebe",
							"tertiary-fixed": "#ffd9e4",
							"surface-container": "#efeee9",
							"on-secondary": "#ffffff",
							"surface-dim": "#dbdad6",
							"on-surface-variant": "#434841",
							"on-error-container": "#93000a",
							"secondary-fixed-dim": "#e9baca",
							"secondary-fixed": "#ffd9e5",
							"secondary": "#795462",
							"on-secondary-fixed-variant": "#5f3d4a"
						},
						"borderRadius": {
							"DEFAULT": "0.25rem",
							"lg": "0.5rem",
							"xl": "0.75rem",
							"full": "9999px"
						},
						"spacing": {
							"container-max": "1200px",
							"section-gap": "80px",
							"margin-desktop": "40px",
							"unit": "4px",
							"margin-mobile": "16px",
							"gutter": "24px"
						},
						"fontFamily": {
							"headline-lg-mobile": ["Poppins"],
							"display-lg": ["Poppins"],
							"body-lg": ["Inter"],
							"headline-lg": ["Poppins"],
							"label-md": ["Inter"],
							"label-sm": ["Inter"],
							"body-md": ["Inter"],
							"headline-md": ["Poppins"]
						},
						"fontSize": {
							"headline-lg-mobile": ["28px", {"lineHeight": "1.3", "fontWeight": "600"}],
							"display-lg": ["48px", {"lineHeight": "1.2", "letterSpacing": "-0.02em", "fontWeight": "600"}],
							"body-lg": ["18px", {"lineHeight": "1.6", "fontWeight": "400"}],
							"headline-lg": ["32px", {"lineHeight": "1.3", "fontWeight": "600"}],
							"label-md": ["14px", {"lineHeight": "1.4", "letterSpacing": "0.01em", "fontWeight": "500"}],
							"label-sm": ["12px", {"lineHeight": "1.2", "fontWeight": "600"}],
							"body-md": ["16px", {"lineHeight": "1.6", "fontWeight": "400"}],
							"headline-md": ["24px", {"lineHeight": "1.4", "fontWeight": "500"}]
						}
					},
				},
			}
		</script>
		<style>
			.material-symbols-outlined {
				font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
			}
			.faq-accordion-content {
				max-height: 0;
				overflow: hidden;
				transition: max-height 0.3s ease-out;
			}
			.faq-accordion-item.active .faq-accordion-content {
				max-height: 500px;
			}
			.faq-accordion-item.active .chevron-icon {
				transform: rotate(180deg);
			}
		</style>
	</head>
	<body class="bg-background text-on-background font-body-md selection:bg-primary-fixed-dim">
		<!-- TopNavBar -->
		<header class="fixed top-0 w-full z-50 bg-surface/90 backdrop-blur-md shadow-sm">
			<nav class="flex justify-between items-center px-margin-desktop py-4 max-w-container-max mx-auto">
				<div class="font-headline-md text-headline-md font-semibold text-primary">Telur Asin Rose</div>
				<div class="hidden md:flex items-center gap-8">
					<a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors duration-200" href="/">Home</a>
					<a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors duration-200" href="/products">Products</a>
					<a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors duration-200" href="/about">About</a>
					<a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors duration-200" href="/faq">FAQ</a>
					<a class="font-label-md text-label-md text-primary border-b-2 border-primary pb-1" href="/contact">Contact</a>
				</div>
				<div class="flex items-center gap-4">
					<button class="material-symbols-outlined text-on-surface-variant hover:text-primary transition-colors">shopping_cart</button>
					<a href="/cart" class="bg-primary text-on-primary px-6 py-2 rounded-full font-label-md hover:opacity-80 transition-opacity">Buy Now</a>
				</div>
			</nav>
		</header>
		<main class="pt-32 pb-section-gap">
			<!-- Hero Section -->
			<section class="max-w-container-max mx-auto px-margin-desktop mb-section-gap">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-gutter items-center">
					<div>
						<h1 class="font-display-lg text-display-lg text-on-surface mb-6">Let's connect and share the warmth.</h1>
						<p class="font-body-lg text-body-lg text-on-surface-variant max-w-lg mb-8">Whether you have a question about our traditional salting process or want to place a bulk order for your next family gathering, we're here to help.</p>
						<div class="space-y-6">
							<div class="flex items-start gap-4">
								<div class="bg-primary-fixed p-3 rounded-xl text-primary">
									<span class="material-symbols-outlined">location_on</span>
								</div>
								<div>
									<h4 class="font-label-md text-label-md text-primary font-bold">Our Home Base</h4>
									<p class="text-on-surface-variant">Jl. Mawar No. 123, Desa Sejahtera<br/>Brebes, Jawa Tengah 52212</p>
								</div>
							</div>
							<div class="flex items-start gap-4">
								<div class="bg-primary-fixed p-3 rounded-xl text-primary">
									<span class="material-symbols-outlined">schedule</span>
								</div>
								<div>
									<h4 class="font-label-md text-label-md text-primary font-bold">Visiting Hours</h4>
									<p class="text-on-surface-variant">Monday - Saturday: 08:00 - 17:00<br/>Sunday: 09:00 - 15:00</p>
								</div>
							</div>
							<div class="flex items-start gap-4">
								<div class="bg-primary-fixed p-3 rounded-xl text-primary">
									<span class="material-symbols-outlined">chat</span>
								</div>
								<div>
									<h4 class="font-label-md text-label-md text-primary font-bold">Quick Chat</h4>
									<p class="text-on-surface-variant">WhatsApp: +62 812-3456-7890<br/>Instagram: @telurasinrose</p>
								</div>
							</div>
						</div>
					</div>
					<!-- Contact Form Card -->
					<div class="bg-surface-container-lowest p-8 rounded-2xl shadow-xl shadow-primary/5 border border-surface-container-highest">
						<form class="space-y-6" id="contactForm">
							<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
								<div class="space-y-2">
									<label class="font-label-md text-on-surface-variant">Full Name</label>
									<input class="w-full bg-surface-container-low border-none rounded-lg p-3 focus:ring-2 focus:ring-primary outline-none transition-all" placeholder="John Doe" type="text"/>
								</div>
								<div class="space-y-2">
									<label class="font-label-md text-on-surface-variant">Email Address</label>
									<input class="w-full bg-surface-container-low border-none rounded-lg p-3 focus:ring-2 focus:ring-primary outline-none transition-all" placeholder="john@example.com" type="email"/>
								</div>
							</div>
							<div class="space-y-2">
								<label class="font-label-md text-on-surface-variant">Subject</label>
								<select class="w-full bg-surface-container-low border-none rounded-lg p-3 focus:ring-2 focus:ring-primary outline-none transition-all">
									<option>Order Inquiry</option>
									<option>Wholesale Request</option>
									<option>Feedback</option>
									<option>Other</option>
								</select>
							</div>
							<div class="space-y-2">
								<label class="font-label-md text-on-surface-variant">Message</label>
								<textarea class="w-full bg-surface-container-low border-none rounded-lg p-3 focus:ring-2 focus:ring-primary outline-none transition-all" placeholder="How can we help you today?" rows="4"></textarea>
							</div>
							<button class="w-full bg-primary text-on-primary font-label-md py-4 rounded-xl hover:opacity-90 active:scale-95 transition-all shadow-lg shadow-primary/20" type="submit">Send Message</button>
						</form>
					</div>
				</div>
			</section>
			<!-- Map Section -->
			<section class="w-full mb-section-gap px-margin-desktop max-w-container-max mx-auto">
				<div class="relative w-full h-[450px] rounded-3xl overflow-hidden shadow-inner bg-surface-container-highest">
					<!-- Map Placeholder -->
					<div class="w-full h-full grayscale opacity-80" data-location="Brebes, Indonesia">
						<img class="w-full h-full object-cover" data-alt="A large, modern minimalist topographic map of a coastal town in Java, Indonesia, styled with a soft sage green and cream color palette. The map features clean white lines for roads and subtle textures for water bodies, maintaining a high-end boutique aesthetic that feels organic and professional. The overall mood is calm and inviting, matching a premium food brand identity." src="https://lh3.googleusercontent.com/aida-public/AB6AXuBcOmRy_6JPY-EM3lFS7o661GpCrI-isVfoPy3RzntsiCRFNq9VVNOhwsTA4zKKZG1ghTW-AQOy4RgZEMeO7PQlEseCK_WZf-TGvzshWUpo5x_Q7H5WapBH-knUcj6GRKbzUsiTiwLQ316y1T2vls1Mcd_ZaMf4qWBmu59WMs9m-mgiPepOQkWx_WMZLvfb5BfjiMqHiVAfydlvvZjl-on6IpjjZTTnTZ4X1RrrZPbFW-oIUSHF-Gc"/>
					</div>
					<div class="absolute bottom-8 left-8 bg-surface/90 backdrop-blur-md p-6 rounded-2xl shadow-xl border border-primary/10 max-w-xs">
						<h5 class="font-headline-md text-headline-md text-primary mb-2">Visit Us</h5>
						<p class="text-on-surface-variant mb-4">Our workshop is open for tours and direct purchases every weekend.</p>
						<a class="text-primary font-bold flex items-center gap-2 hover:underline" href="#">
							Get Directions <span class="material-symbols-outlined text-sm">open_in_new</span>
						</a>
					</div>
				</div>
			</section>
			<!-- FAQ Section -->
			<section class="max-w-3xl mx-auto px-margin-desktop">
				<div class="text-center mb-12">
					<h2 class="font-headline-lg text-headline-lg text-on-surface mb-4">Frequently Asked Questions</h2>
					<p class="text-on-surface-variant">Quick answers to common questions about our products and shipping.</p>
				</div>
				<div class="space-y-4">
					<!-- FAQ Item 1 -->
					<div class="faq-accordion-item bg-surface-container-low rounded-2xl overflow-hidden transition-all border border-transparent hover:border-primary-fixed">
						<button class="w-full px-6 py-5 flex justify-between items-center text-left" onclick="toggleFaq(this)">
							<span class="font-headline-md text-label-md font-semibold text-on-surface">How long can the salted eggs last?</span>
							<span class="material-symbols-outlined text-primary transition-transform duration-300 chevron-icon">expand_more</span>
						</button>
						<div class="faq-accordion-content">
							<div class="px-6 pb-6 text-on-surface-variant font-body-md">
								Our traditionally prepared salted eggs can last up to 4 weeks at room temperature and up to 6 weeks when refrigerated. We always recommend keeping them in a cool, dry place away from direct sunlight.
							</div>
						</div>
					</div>
					<!-- FAQ Item 2 -->
					<div class="faq-accordion-item bg-surface-container-low rounded-2xl overflow-hidden transition-all border border-transparent hover:border-primary-fixed">
						<button class="w-full px-6 py-5 flex justify-between items-center text-left" onclick="toggleFaq(this)">
							<span class="font-headline-md text-label-md font-semibold text-on-surface">Do you offer international shipping?</span>
							<span class="material-symbols-outlined text-primary transition-transform duration-300 chevron-icon">expand_more</span>
						</button>
						<div class="faq-accordion-content">
							<div class="px-6 pb-6 text-on-surface-variant font-body-md">
								Currently, we only ship within Indonesia to ensure the freshness and integrity of our eggs. We are exploring specialized vacuum-sealed options for potential international distribution in the future.
							</div>
						</div>
					</div>
					<!-- FAQ Item 3 -->
					<div class="faq-accordion-item bg-surface-container-low rounded-2xl overflow-hidden transition-all border border-transparent hover:border-primary-fixed">
						<button class="w-full px-6 py-5 flex justify-between items-center text-left" onclick="toggleFaq(this)">
							<span class="font-headline-md text-label-md font-semibold text-on-surface">What makes 'Rose' different from other brands?</span>
							<span class="material-symbols-outlined text-primary transition-transform duration-300 chevron-icon">expand_more</span>
						</button>
						<div class="faq-accordion-content">
							<div class="px-6 pb-6 text-on-surface-variant font-body-md">
								Telur Asin Rose uses a proprietary 21-day brining process with organic clay and sea salt. This results in a perfectly oily, bright orange yolk (masir) and a delicate, less-pungent white compared to industrial brands.
							</div>
						</div>
					</div>
					<!-- FAQ Item 4 -->
					<div class="faq-accordion-item bg-surface-container-low rounded-2xl overflow-hidden transition-all border border-transparent hover:border-primary-fixed">
						<button class="w-full px-6 py-5 flex justify-between items-center text-left" onclick="toggleFaq(this)">
							<span class="font-headline-md text-label-md font-semibold text-on-surface">Can I request a custom salt level?</span>
							<span class="material-symbols-outlined text-primary transition-transform duration-300 chevron-icon">expand_more</span>
						</button>
						<div class="faq-accordion-content">
							<div class="px-6 pb-6 text-on-surface-variant font-body-md">
								For bulk orders (minimum 100 eggs), we can adjust the brining time to achieve your preferred level of saltiness. Please contact us via WhatsApp for wholesale customizations.
							</div>
						</div>
					</div>
				</div>
			</section>
		</main>
		<!-- Footer -->
		<footer class="bg-primary text-on-primary w-full">
			<div class="grid grid-cols-1 md:grid-cols-4 gap-gutter px-margin-desktop py-section-gap max-w-container-max mx-auto">
				<div class="md:col-span-1">
					<div class="font-headline-md text-headline-md font-semibold text-on-primary mb-6">Telur Asin Rose</div>
					<p class="text-on-primary/80 font-body-md">Handcrafting the finest salted eggs with tradition, love, and the highest quality ingredients since 2012.</p>
				</div>
				<div>
					<h4 class="font-label-md text-label-md font-bold mb-6 text-secondary-container">Shop</h4>
					<ul class="space-y-3">
						<li><a class="text-on-primary/80 hover:text-secondary-container transition-colors" href="/products">Products</a></li>
						<li><a class="text-on-primary/80 hover:text-secondary-container transition-colors" href="/products">Best Sellers</a></li>
						<li><a class="text-on-primary/80 hover:text-secondary-container transition-colors" href="/products">Gift Boxes</a></li>
						<li><a class="text-on-primary/80 hover:text-secondary-container transition-colors" href="/products">Bulk Orders</a></li>
					</ul>
				</div>
				<div>
					<h4 class="font-label-md text-label-md font-bold mb-6 text-secondary-container">Company</h4>
					<ul class="space-y-3">
						<li><a class="text-on-primary/80 hover:text-secondary-container transition-colors" href="/about">About Us</a></li>
						<li><a class="text-on-primary/80 hover:text-secondary-container transition-colors" href="/faq">FAQ</a></li>
						<li><a class="text-on-primary/80 hover:text-secondary-container transition-colors" href="/contact">Contact</a></li>
						<li><a class="text-on-primary/80 hover:text-secondary-container transition-colors" href="#">Careers</a></li>
					</ul>
				</div>
				<div>
					<h4 class="font-label-md text-label-md font-bold mb-6 text-secondary-container">Connect</h4>
					<ul class="space-y-3">
						<li><a class="text-on-primary/80 hover:text-secondary-container transition-colors" href="#">WhatsApp</a></li>
						<li><a class="text-on-primary/80 hover:text-secondary-container transition-colors" href="#">Instagram</a></li>
						<li><a class="text-on-primary/80 hover:text-secondary-container transition-colors" href="#">Facebook</a></li>
						<li><a class="text-on-primary/80 hover:text-secondary-container transition-colors" href="#">Email Us</a></li>
					</ul>
				</div>
			</div>
			<div class="max-w-container-max mx-auto px-margin-desktop py-8 border-t border-on-primary/10 text-center md:text-left">
				<p class="text-on-primary/60 text-label-sm">© 2024 Telur Asin Rose. Made with love. All Rights Reserved.</p>
			</div>
		</footer>
		<script>
			function toggleFaq(button) {
				const item = button.parentElement;
				const isActive = item.classList.contains('active');
				
				// Close all items
				document.querySelectorAll('.faq-accordion-item').forEach(el => {
					el.classList.remove('active');
				});
				
				// Open clicked item if it wasn't active
				if (!isActive) {
					item.classList.add('active');
				}
			}

			// Simple form submission micro-interaction
			document.getElementById('contactForm').addEventListener('submit', function(e) {
				e.preventDefault();
				const btn = this.querySelector('button');
				const originalText = btn.innerText;
				btn.innerText = 'Sending...';
				btn.disabled = true;
				
				setTimeout(() => {
					btn.innerText = 'Message Sent!';
					btn.classList.replace('bg-primary', 'bg-primary-fixed-dim');
					btn.classList.add('text-primary');
					this.reset();
					
					setTimeout(() => {
						btn.innerText = originalText;
						btn.classList.replace('bg-primary-fixed-dim', 'bg-primary');
						btn.classList.remove('text-primary');
						btn.disabled = false;
					}, 3000);
				}, 1500);
			});
		</script>
	</body>
</html>