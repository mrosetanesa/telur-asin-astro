---
const title = "About Us | Telur Asin Rose";
const description = "Learn about our heritage, values, and commitment to quality";
---

<html class="scroll-smooth" lang="en">
	<head>
		<meta charset="utf-8"/>
		<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{title}</title>
		<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
		<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Inter:wght@400;500;600&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Poppins:wght@100..900&display=swap" rel="stylesheet"/>
		<script id="tailwind-config">
			tailwind.config = {
				darkMode: "class",
				theme: {
					extend: {
						"colors": {
							"background": "#faf9f5",
							"surface-container-highest": "#e3e2de",
							"primary-fixed": "#ceeac5",
							"secondary-container": "#fecddd",
							"error": "#ba1a1a",
							"outline": "#747970",
							"on-primary": "#ffffff",
							"primary-fixed-dim": "#b3ceab",
							"inverse-on-surface": "#f2f1ec",
							"surface-tint": "#4c6548",
							"surface-container-low": "#f5f4ef",
							"on-tertiary-container": "#66404d",
							"tertiary-fixed-dim": "#ecb9c9",
							"tertiary": "#7b5361",
							"primary-container": "#a8c3a0",
							"on-primary-fixed": "#0a2009",
							"on-surface": "#1b1c19",
							"on-primary-fixed-variant": "#354d31",
							"surface-container-high": "#e9e8e4",
							"surface-variant": "#e3e2de",
							"on-tertiary-fixed": "#30121e",
							"error-container": "#ffdad6",
							"inverse-surface": "#30312e",
							"on-secondary-container": "#7a5562",
							"on-primary-container": "#3a5135",
							"inverse-primary": "#b3ceab",
							"surface": "#faf9f5",
							"surface-container-lowest": "#ffffff",
							"on-secondary-fixed": "#2e131e",
							"primary": "#4c6548",
							"on-background": "#1b1c19",
							"on-tertiary": "#ffffff",
							"on-error": "#ffffff",
							"outline-variant": "#c3c8be",
							"surface-bright": "#faf9f5",
							"on-tertiary-fixed-variant": "#613c49",
							"tertiary-container": "#e0aebe",
							"tertiary-fixed": "#ffd9e4",
							"surface-container": "#efeee9",
							"on-secondary": "#ffffff",
							"surface-dim": "#dbdad6",
							"on-surface-variant": "#434841",
							"on-error-container": "#93000a",
							"secondary-fixed-dim": "#e9baca",
							"secondary-fixed": "#ffd9e5",
							"secondary": "#795462",
							"on-secondary-fixed-variant": "#5f3d4a"
						},
						"borderRadius": {
							"DEFAULT": "0.25rem",
							"lg": "0.5rem",
							"xl": "0.75rem",
							"full": "9999px"
						},
						"spacing": {
							"container-max": "1200px",
							"section-gap": "80px",
							"margin-desktop": "40px",
							"unit": "4px",
							"margin-mobile": "16px",
							"gutter": "24px"
						},
						"fontFamily": {
							"headline-lg-mobile": ["Poppins"],
							"display-lg": ["Poppins"],
							"body-lg": ["Inter"],
							"headline-lg": ["Poppins"],
							"label-md": ["Inter"],
							"label-sm": ["Inter"],
							"body-md": ["Inter"],
							"headline-md": ["Poppins"]
						},
						"fontSize": {
							"headline-lg-mobile": ["28px", {"lineHeight": "1.3", "fontWeight": "600"}],
							"display-lg": ["48px", {"lineHeight": "1.2", "letterSpacing": "-0.02em", "fontWeight": "600"}],
							"body-lg": ["18px", {"lineHeight": "1.6", "fontWeight": "400"}],
							"headline-lg": ["32px", {"lineHeight": "1.3", "fontWeight": "600"}],
							"label-md": ["14px", {"lineHeight": "1.4", "letterSpacing": "0.01em", "fontWeight": "500"}],
							"label-sm": ["12px", {"lineHeight": "1.2", "fontWeight": "600"}],
							"body-md": ["16px", {"lineHeight": "1.6", "fontWeight": "400"}],
							"headline-md": ["24px", {"lineHeight": "1.4", "fontWeight": "500"}]
						}
					},
				},
			}
		</script>
		<style>
			.material-symbols-outlined {
				font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
			}
			.organic-blob {
				border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
			}
			.glass-header {
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
			}
		</style>
	</head>
	<body class="bg-background text-on-surface font-body-md overflow-x-hidden">
		<!-- TopNavBar -->
		<header class="fixed top-0 w-full z-50 bg-surface/90 glass-header shadow-sm">
			<nav class="flex justify-between items-center px-margin-desktop py-4 max-w-container-max mx-auto">
				<div class="font-headline-md text-headline-md font-semibold text-primary">Telur Asin Rose</div>
				<div class="hidden md:flex items-center space-x-8">
					<a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors duration-200" href="/">Home</a>
					<a class="font-label-md text-label-md text-primary border-b-2 border-primary pb-1 transition-colors duration-200" href="/about">About</a>
					<a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors duration-200" href="/products">Products</a>
					<a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors duration-200" href="/faq">FAQ</a>
					<a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors duration-200" href="/contact">Contact</a>
				</div>
				<div class="flex items-center space-x-4">
					<button class="material-symbols-outlined text-primary p-2">shopping_cart</button>
					<a href="/cart" class="hidden md:block bg-primary text-on-primary px-8 py-2 rounded-lg font-label-md hover:opacity-90 transition-opacity">Buy Now</a>
				</div>
			</nav>
		</header>
		<main class="pt-24">
			<!-- Hero Section / Brand Story -->
			<section class="px-margin-mobile md:px-margin-desktop py-section-gap max-w-container-max mx-auto overflow-hidden">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-gutter items-center">
					<div class="relative order-2 md:order-1">
						<div class="absolute -top-10 -left-10 w-64 h-64 bg-secondary-container/30 organic-blob -z-10 animate-pulse"></div>
						<div class="rounded-2xl overflow-hidden shadow-2xl rotate-2 hover:rotate-0 transition-transform duration-500">
							<img class="w-full aspect-[4/5] object-cover" data-alt="A warm, sun-drenched photography of a traditional kitchen scene featuring a bowl of artisanal salted duck eggs. The lighting is soft and golden, emphasizing the natural textures of the shells. The aesthetic is clean and premium, with sage green linen napkins and subtle floral accents in the background, conveying a sense of domestic warmth and heritage." src="https://lh3.googleusercontent.com/aida-public/AB6AXuCuSwQu7bDwkxTAiPmcnDt5ZhYSMEksnUeLp9r6bFOohechRB0BCz4tNdbp9jnNWUHUgbfJpQF8c9hAYqGa8cY08VrkznN5gpkue1hychBQ0a3_z13V_LHBzd7d8IBAvHqjs0C3-wGzgEwqe2agFdAWOmTbNR7O3Fm410msORmzcAArfmvTP-tP5tPhK1rZ0VTqDCWtdTfq7BiDqKX_cZc9We6K5xO50SkVdbbax_kFrHSKwst9eLk"/>
						</div>
					</div>
					<div class="order-1 md:order-2 space-y-6">
						<span class="inline-block px-4 py-1 rounded-full bg-secondary-container text-on-secondary-container font-label-sm text-label-sm">Our Legacy</span>
						<h1 class="font-display-lg text-display-lg text-primary leading-tight">The Story of Rose</h1>
						<p class="font-body-lg text-body-lg text-on-surface-variant">
							Born from a small family kitchen in 1988, Telur Asin Rose began with a single mission: to create the perfect salted egg that reminds everyone of home. What started as a local neighborhood secret has blossomed into a symbol of artisanal quality and traditional excellence.
						</p>
						<p class="font-body-md text-body-md text-on-surface-variant">
							Our name, "Rose", reflects the delicate balance we strike between robust flavor and elegant presentation. Every egg is hand-selected and treated with the same love and care that our founder, Mama Rose, poured into her very first batch over three decades ago.
						</p>
						<div class="pt-4">
							<button class="bg-primary text-on-primary px-8 py-4 rounded-lg font-label-md hover:shadow-lg transition-all active:scale-95">Discover Our Secret</button>
						</div>
					</div>
				</div>
			</section>
			<!-- Vision & Mission -->
			<section class="bg-surface-container-low py-section-gap">
				<div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto text-center mb-16">
					<h2 class="font-headline-lg text-headline-lg text-primary mb-4">Values That Guide Us</h2>
					<div class="w-24 h-1 bg-tertiary-container mx-auto rounded-full"></div>
				</div>
				<div class="px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto grid grid-cols-1 md:grid-cols-2 gap-gutter">
					<div class="bg-surface-container-lowest p-10 rounded-3xl shadow-sm border border-surface-container-highest group hover:border-primary/20 transition-colors">
						<div class="w-16 h-16 bg-primary-fixed rounded-2xl flex items-center justify-center mb-6 text-primary group-hover:scale-110 transition-transform">
							<span class="material-symbols-outlined text-4xl">visibility</span>
						</div>
						<h3 class="font-headline-md text-headline-md text-primary mb-4">Our Vision</h3>
						<p class="font-body-md text-body-md text-on-surface-variant">
							To be the global benchmark for artisanal salted eggs, preserving traditional Indonesian heritage while embracing modern sustainable practices for a healthier tomorrow.
						</p>
					</div>
					<div class="bg-surface-container-lowest p-10 rounded-3xl shadow-sm border border-surface-container-highest group hover:border-tertiary/20 transition-colors">
						<div class="w-16 h-16 bg-secondary-container rounded-2xl flex items-center justify-center mb-6 text-tertiary group-hover:scale-110 transition-transform">
							<span class="material-symbols-outlined text-4xl">favorite</span>
						</div>
						<h3 class="font-headline-md text-headline-md text-primary mb-4">Our Mission</h3>
						<p class="font-body-md text-body-md text-on-surface-variant">
							We are committed to sourcing only the finest organic eggs, utilizing natural Himalayan salt, and maintaining a slow-curing process that ensures a rich, creamy yolk and perfectly balanced flavor in every bite.
						</p>
					</div>
				</div>
			</section>
			<!-- Production Process -->
			<section class="px-margin-mobile md:px-margin-desktop py-section-gap max-w-container-max mx-auto">
				<div class="text-center mb-16">
					<h2 class="font-headline-lg text-headline-lg text-primary">The Art of Salting</h2>
					<p class="font-body-md text-body-md text-on-surface-variant mt-2">A patient journey from farm to your table.</p>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-4 gap-8 relative">
					<!-- Connecting Line (Desktop) -->
					<div class="hidden md:block absolute top-12 left-0 w-full h-0.5 bg-outline-variant/30 -z-10"></div>
					<!-- Step 1 -->
					<div class="flex flex-col items-center text-center group">
						<div class="w-24 h-24 bg-surface-container-highest rounded-full flex items-center justify-center mb-6 border-4 border-background group-hover:bg-primary-fixed transition-colors duration-300">
							<span class="material-symbols-outlined text-primary text-3xl">task_alt</span>
						</div>
						<h4 class="font-label-md text-label-md font-bold text-primary mb-2">1. Selection</h4>
						<p class="font-label-sm text-label-sm text-on-surface-variant">Hand-picking the finest organic duck eggs from our local partners.</p>
					</div>
					<!-- Step 2 -->
					<div class="flex flex-col items-center text-center group">
						<div class="w-24 h-24 bg-surface-container-highest rounded-full flex items-center justify-center mb-6 border-4 border-background group-hover:bg-primary-fixed transition-colors duration-300">
							<span class="material-symbols-outlined text-primary text-3xl">clean_hands</span>
						</div>
						<h4 class="font-label-md text-label-md font-bold text-primary mb-2">2. Cleaning</h4>
						<p class="font-label-sm text-label-sm text-on-surface-variant">Meticulous cleaning using natural spring water and clay.</p>
					</div>
					<!-- Step 3 -->
					<div class="flex flex-col items-center text-center group">
						<div class="w-24 h-24 bg-surface-container-highest rounded-full flex items-center justify-center mb-6 border-4 border-background group-hover:bg-primary-fixed transition-colors duration-300">
							<span class="material-symbols-outlined text-primary text-3xl">hourglass_empty</span>
						</div>
						<h4 class="font-label-md text-label-md font-bold text-primary mb-2">3. Salting</h4>
						<p class="font-label-sm text-label-sm text-on-surface-variant">A 28-day curing process in our signature Himalayan sea salt mix.</p>
					</div>
					<!-- Step 4 -->
					<div class="flex flex-col items-center text-center group">
						<div class="w-24 h-24 bg-surface-container-highest rounded-full flex items-center justify-center mb-6 border-4 border-background group-hover:bg-primary-fixed transition-colors duration-300">
							<span class="material-symbols-outlined text-primary text-3xl">cooking</span>
						</div>
						<h4 class="font-label-md text-label-md font-bold text-primary mb-2">4. Cooking</h4>
						<p class="font-label-sm text-label-sm text-on-surface-variant">Slow-steamed to perfection to lock in the rich, buttery texture.</p>
					</div>
				</div>
			</section>
			<!-- Commitment to Quality -->
			<section class="px-margin-mobile md:px-margin-desktop py-section-gap max-w-container-max mx-auto">
				<div class="bg-primary-container/20 rounded-[3rem] p-8 md:p-16 flex flex-col md:flex-row items-center gap-gutter relative overflow-hidden">
					<!-- Background decoration -->
					<div class="absolute -right-20 -bottom-20 w-80 h-80 bg-primary-fixed/20 organic-blob"></div>
					<div class="flex-1 space-y-6 relative z-10">
						<h2 class="font-headline-lg text-headline-lg text-primary">Uncompromising Quality</h2>
						<p class="font-body-md text-body-md text-on-surface-variant">
							Our facility maintains ISO certification and rigorous hygiene protocols. We believe that true quality isn't just about the final taste, but the integrity of every single ingredient and process that goes into it.
						</p>
						<ul class="space-y-4">
							<li class="flex items-center gap-3">
								<span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">check_circle</span>
								<span class="font-label-md text-label-md">100% Antibiotic-free Organic Eggs</span>
							</li>
							<li class="flex items-center gap-3">
								<span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">check_circle</span>
								<span class="font-label-md text-label-md">No Artificial Preservatives or Dyes</span>
							</li>
							<li class="flex items-center gap-3">
								<span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">check_circle</span>
								<span class="font-label-md text-label-md">Traditional Slow-Curing Method</span>
							</li>
						</ul>
					</div>
					<div class="flex-1 w-full max-w-md relative z-10">
						<div class="rounded-3xl overflow-hidden shadow-xl border-4 border-surface-container-lowest">
							<img class="w-full h-auto" data-alt="Close-up macro photography of a halved salted egg, showing the vibrant, oily orange yolk with a rich, creamy texture and a perfectly set white. The background is a soft, minimalist blur of warm sage green tones. The lighting is bright and clean, highlighting the freshness and high-end artisanal quality of the food product." src="https://lh3.googleusercontent.com/aida-public/AB6AXuD6MOjU47VWOvWCZsctIQO_6FECrQzRODL7oeHJwVJD9gRIiq3p5kshb2l_YdcOsTMYtmXgBkImBmNvyuT56COx8NlCJFAgFPelzzOXKuZqmLYMe2SDVyU2q1udKJ_oSRsyMzFQn7tXvw38kDVYJCWaHNMAAZQ9Nl3rXkq2A9Bx8WlxHR6drXACetMooAIUnPvx9_94204g5XrQiM39nbfaKt_YTJpit4KC0pqnfQePfVo6zO1SGbc"/>
						</div>
					</div>
				</div>
			</section>
		</main>
		<!-- Footer -->
		<footer class="bg-primary dark:bg-on-primary-fixed-variant text-on-primary mt-section-gap">
			<div class="max-w-container-max mx-auto px-margin-desktop py-section-gap grid grid-cols-1 md:grid-cols-4 gap-gutter">
				<div class="space-y-4">
					<div class="font-headline-md text-headline-md font-semibold text-on-primary">Telur Asin Rose</div>
					<p class="font-body-md text-body-md text-on-primary/80">Delivering the golden tradition of artisanal salted eggs since 1988.</p>
				</div>
				<div class="space-y-4">
					<h4 class="font-label-md text-label-md font-bold uppercase tracking-wider">Quick Links</h4>
					<ul class="space-y-2">
						<li><a class="font-label-md text-label-md text-on-primary/80 hover:text-secondary-container transition-colors" href="/">Home</a></li>
						<li><a class="font-label-md text-label-md text-secondary-container font-bold" href="/about">About Us</a></li>
						<li><a class="font-label-md text-label-md text-on-primary/80 hover:text-secondary-container transition-colors" href="/products">Products</a></li>
						<li><a class="font-label-md text-label-md text-on-primary/80 hover:text-secondary-container transition-colors" href="/faq">FAQ</a></li>
					</ul>
				</div>
				<div class="space-y-4">
					<h4 class="font-label-md text-label-md font-bold uppercase tracking-wider">Connect</h4>
					<ul class="space-y-2">
						<li><a class="font-label-md text-label-md text-on-primary/80 hover:text-secondary-container transition-colors" href="#">WhatsApp</a></li>
						<li><a class="font-label-md text-label-md text-on-primary/80 hover:text-secondary-container transition-colors" href="#">Instagram</a></li>
						<li><a class="font-label-md text-label-md text-on-primary/80 hover:text-secondary-container transition-colors" href="#">Facebook</a></li>
					</ul>
				</div>
				<div class="space-y-4">
					<h4 class="font-label-md text-label-md font-bold uppercase tracking-wider">Newsletter</h4>
					<div class="flex gap-2">
						<input class="bg-on-primary-fixed-variant border border-on-primary/20 rounded-lg px-4 py-2 text-on-primary w-full focus:ring-2 focus:ring-secondary-container outline-none placeholder:text-on-primary/40" placeholder="Email address" type="email"/>
						<button class="bg-secondary-container text-on-secondary-container px-4 py-2 rounded-lg hover:scale-95 transition-transform"><span class="material-symbols-outlined">send</span></button>
					</div>
				</div>
			</div>
			<div class="max-w-container-max mx-auto px-margin-desktop py-6 border-t border-on-primary/10 text-center font-label-md text-label-md text-on-primary/60">
				© 2024 Telur Asin Rose. Made with love.
			</div>
		</footer>
		<script>
			// Simple scroll reveal interaction
			const observerOptions = {
				threshold: 0.1
			};

			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('opacity-100', 'translate-y-0');
						entry.target.classList.remove('opacity-0', 'translate-y-10');
					}
				});
			}, observerOptions);

			document.querySelectorAll('section').forEach(section => {
				section.classList.add('transition-all', 'duration-700', 'opacity-0', 'translate-y-10');
				observer.observe(section);
			});

			// Add sticky header behavior
			let lastScroll = 0;
			window.addEventListener('scroll', () => {
				const currentScroll = window.pageYOffset;
				const header = document.querySelector('header');
				
				if (currentScroll <= 0) {
					header.classList.remove('shadow-lg');
					return;
				}
				
				if (currentScroll > lastScroll) {
					header.style.transform = 'translateY(-100%)';
				} else {
					header.style.transform = 'translateY(0)';
					header.classList.add('shadow-lg');
				}
				lastScroll = currentScroll;
			});
		</script>
	</body>
</html>