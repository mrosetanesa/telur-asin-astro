---
const title = "Your Basket | Telur Asin Rose";
const description = "Review your selection of premium artisanal salted eggs and proceed to checkout via WhatsApp.";
---

<html class="scroll-smooth" lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>{title}</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Inter:wght@400;500;600&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Poppins:wght@100..900&display=swap" rel="stylesheet"/>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        .glass-header {
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }
        /* Hide scrollbar for Chrome, Safari and Opera */
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
        /* Hide scrollbar for IE, Edge and Firefox */
        .no-scrollbar {
            -ms-overflow-style: none;  /* IE and Edge */
            scrollbar-width: none;  /* Firefox */
        }
    </style>
<script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "background": "#faf9f5",
                        "surface-container-highest": "#e3e2de",
                        "primary-fixed": "#ceeac5",
                        "secondary-container": "#fecddd",
                        "error": "#ba1a1a",
                        "outline": "#747970",
                        "on-primary": "#ffffff",
                        "primary-fixed-dim": "#b3ceab",
                        "inverse-on-surface": "#f2f1ec",
                        "surface-tint": "#4c6548",
                        "surface-container-low": "#f5f4ef",
                        "on-tertiary-container": "#66404d",
                        "tertiary-fixed-dim": "#ecb9c9",
                        "tertiary": "#7b5361",
                        "primary-container": "#a8c3a0",
                        "on-primary-fixed": "#0a2009",
                        "on-surface": "#1b1c19",
                        "on-primary-fixed-variant": "#354d31",
                        "surface-container-high": "#e9e8e4",
                        "surface-variant": "#e3e2de",
                        "on-tertiary-fixed": "#30121e",
                        "error-container": "#ffdad6",
                        "inverse-surface": "#30312e",
                        "on-secondary-container": "#7a5562",
                        "on-primary-container": "#3a5135",
                        "inverse-primary": "#b3ceab",
                        "surface": "#faf9f5",
                        "surface-container-lowest": "#ffffff",
                        "on-secondary-fixed": "#2e131e",
                        "primary": "#4c6548",
                        "on-background": "#1b1c19",
                        "on-tertiary": "#ffffff",
                        "on-error": "#ffffff",
                        "outline-variant": "#c3c8be",
                        "surface-bright": "#faf9f5",
                        "on-tertiary-fixed-variant": "#613c49",
                        "tertiary-container": "#e0aebe",
                        "tertiary-fixed": "#ffd9e4",
                        "surface-container": "#efeee9",
                        "on-secondary": "#ffffff",
                        "surface-dim": "#dbdad6",
                        "on-surface-variant": "#434841",
                        "on-error-container": "#93000a",
                        "secondary-fixed-dim": "#e9baca",
                        "secondary-fixed": "#ffd9e5",
                        "secondary": "#795462",
                        "on-secondary-fixed-variant": "#5f3d4a"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "container-max": "1200px",
                        "section-gap": "80px",
                        "margin-desktop": "40px",
                        "unit": "4px",
                        "margin-mobile": "16px",
                        "gutter": "24px"
                    },
                    "fontFamily": {
                        "headline-lg-mobile": ["Poppins"],
                        "display-lg": ["Poppins"],
                        "body-lg": ["Inter"],
                        "headline-lg": ["Poppins"],
                        "label-md": ["Inter"],
                        "label-sm": ["Inter"],
                        "body-md": ["Inter"],
                        "headline-md": ["Poppins"]
                    },
                    "fontSize": {
                        "headline-lg-mobile": ["28px", { "lineHeight": "1.3", "fontWeight": "600" }],
                        "display-lg": ["48px", { "lineHeight": "1.2", "letterSpacing": "-0.02em", "fontWeight": "600" }],
                        "body-lg": ["18px", { "lineHeight": "1.6", "fontWeight": "400" }],
                        "headline-lg": ["32px", { "lineHeight": "1.3", "fontWeight": "600" }],
                        "label-md": ["14px", { "lineHeight": "1.4", "letterSpacing": "0.01em", "fontWeight": "500" }],
                        "label-sm": ["12px", { "lineHeight": "1.2", "fontWeight": "600" }],
                        "body-md": ["16px", { "lineHeight": "1.6", "fontWeight": "400" }],
                        "headline-md": ["24px", { "lineHeight": "1.4", "fontWeight": "500" }]
                    }
                },
            },
        }
    </script>
</head>
<body class="bg-background text-on-surface font-body-md selection:bg-primary-fixed-dim selection:text-on-primary-fixed">
<!-- Top Navigation Bar -->
<header class="fixed top-0 w-full z-50 bg-surface/90 backdrop-blur-md shadow-sm">
<div class="flex justify-between items-center px-margin-mobile md:px-margin-desktop py-4 max-w-container-max mx-auto">
<a class="font-headline-md text-headline-md font-semibold text-primary" href="/">Telur Asin Rose</a>
<nav class="hidden md:flex items-center gap-8">
<a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors duration-200" href="/">Home</a>
<a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors duration-200" href="/products">Products</a>
<a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors duration-200" href="/about">About</a>
<a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors duration-200" href="/faq">FAQ</a>
<a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors duration-200" href="/contact">Contact</a>
</nav>
<div class="flex items-center gap-4">
<button class="relative p-2 text-primary">
<span class="material-symbols-outlined">shopping_cart</span>
<span class="absolute top-0 right-0 bg-secondary text-on-secondary text-[10px] w-4 h-4 flex items-center justify-center rounded-full">2</span>
</button>
<a href="/cart" class="hidden md:block bg-primary text-on-primary px-6 py-2 rounded-lg font-label-md hover:bg-on-primary-fixed-variant transition-all duration-200">Buy Now</a>
</div>
</div>
</header>
<main class="pt-24 pb-section-gap px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
<!-- Hero Section / Title -->
<div class="mb-12">
<h1 class="font-headline-lg text-headline-lg text-on-surface mb-2">Shopping Basket</h1>
<p class="text-on-surface-variant">Review your selection of artisanal salted eggs.</p>
</div>
<div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
<!-- Product List Section -->
<div class="lg:col-span-8">
<!-- Cart Header (Desktop) -->
<div class="hidden md:grid grid-cols-12 border-b border-outline-variant pb-4 mb-6 text-on-surface-variant font-label-md">
<div class="col-span-6">Product</div>
<div class="col-span-2 text-center">Price</div>
<div class="col-span-2 text-center">Quantity</div>
<div class="col-span-2 text-right">Subtotal</div>
</div>
<!-- Cart Items -->
<div class="space-y-6">
<!-- Item 1 -->
<div class="grid grid-cols-1 md:grid-cols-12 items-center bg-surface-container-low p-4 rounded-xl shadow-sm border border-surface-container-highest transition-transform hover:scale-[1.005]">
<div class="md:col-span-6 flex items-center gap-4">
<div class="w-20 h-20 bg-surface-container rounded-lg flex-shrink-0 overflow-hidden">
<img class="w-full h-full object-cover" data-alt="A macro close-up of a premium Grade A salted egg with a vibrant orange yolk, sitting on a rustic wooden table under warm, soft morning light. The setting is clean and minimalist with organic textures, reflecting the boutique and artisanal quality of Telur Asin Rose. The palette features warm whites, soft creams, and earth tones." src="https://lh3.googleusercontent.com/aida-public/AB6AXuAJCTu355uGe8PjjCiUDMm4e99LPC5cuNAAv2i8MUgOUeZvqM2j8RFpsjVkpLbpAJpQQweIdHkGZheATXpV8ozkkZApChtL1zusSX2VPuy5EoCbnU8zg8YpkRdtUP8K0I6R9ie-ebesdb7rFGod8ka5QPuVtj2xb15CB17eexVPq3ZKNj4LxQcmTm3j0YWILX4P-npYBvcQFe2r0VVwhL5LBlzVknkTNlBOgyw2wj5RjXWrLDdWGP4"/>
</div>
<div>
<h3 class="font-headline-md text-[18px] text-on-surface">Premium Grade A (6 pcs)</h3>
<p class="text-label-sm text-on-surface-variant">Traditional Clay Brine</p>
<button class="md:hidden mt-2 flex items-center text-error text-label-sm gap-1">
<span class="material-symbols-outlined text-[18px]">delete</span> Remove
                                </button>
</div>
</div>
<div class="hidden md:block md:col-span-2 text-center text-on-surface">Rp 45,000</div>
<div class="md:col-span-2 flex justify-center py-4 md:py-0">
<div class="flex items-center border border-outline-variant rounded-full bg-surface-container-lowest">
<button class="w-8 h-8 flex items-center justify-center text-on-surface hover:bg-surface-container transition-colors rounded-full">-</button>
<span class="w-10 text-center font-label-md">2</span>
<button class="w-8 h-8 flex items-center justify-center text-on-surface hover:bg-surface-container transition-colors rounded-full">+</button>
</div>
</div>
<div class="md:col-span-2 text-right flex items-center justify-between md:justify-end">
<span class="md:hidden text-on-surface-variant font-label-sm">Total:</span>
<span class="font-semibold text-primary">Rp 90,000</span>
<button class="hidden md:flex ml-4 p-1 text-on-surface-variant hover:text-error transition-colors">
<span class="material-symbols-outlined">close</span>
</button>
</div>
</div>
<!-- Item 2 -->
<div class="grid grid-cols-1 md:grid-cols-12 items-center bg-surface-container-low p-4 rounded-xl shadow-sm border border-surface-container-highest transition-transform hover:scale-[1.005]">
<div class="md:col-span-6 flex items-center gap-4">
<div class="w-20 h-20 bg-surface-container rounded-lg flex-shrink-0 overflow-hidden">
<img class="w-full h-full object-cover" data-alt="A stack of beautifully prepared smoked salted eggs, showing their unique dark brown shells on a minimalist ceramic plate. The lighting is soft and airy, highlighting the artisanal texture of the shells. The overall aesthetic is high-end boutique retail, focusing on fresh, natural ingredients with a soft feminine touch and Sage Green accents." src="https://lh3.googleusercontent.com/aida-public/AB6AXuDWnLNIaBqIalwTeqzBzOdWlD-1hbZ8dxBf4qU-3-1oC-ULnxkAHxi8X0knmLJ1MEFEpOsjHY1dDvHuht1PtuROirUQbpvJ9-UqMzjbdak7gBBLHjtpDC4mp8l_YOg7WgpjiX5hMtZQF2hkJARsWL7ZX564wGG6iX4cQfr3Ae9BrqdIbcXWxKI3CoPI7vpmrFQQ7KZwZbixbdL-JGeu5VgICS8Avo00PUg8M4QRjeTsTrrQtLAHQGs"/>
</div>
<div>
<h3 class="font-headline-md text-[18px] text-on-surface">Smoked Salted Egg (4 pcs)</h3>
<p class="text-label-sm text-on-surface-variant">Signature Wood-Smoked</p>
<button class="md:hidden mt-2 flex items-center text-error text-label-sm gap-1">
<span class="material-symbols-outlined text-[18px]">delete</span> Remove
                                </button>
</div>
</div>
<div class="hidden md:block md:col-span-2 text-center text-on-surface">Rp 38,000</div>
<div class="md:col-span-2 flex justify-center py-4 md:py-0">
<div class="flex items-center border border-outline-variant rounded-full bg-surface-container-lowest">
<button class="w-8 h-8 flex items-center justify-center text-on-surface hover:bg-surface-container transition-colors rounded-full">-</button>
<span class="w-10 text-center font-label-md">1</span>
<button class="w-8 h-8 flex items-center justify-center text-on-surface hover:bg-surface-container transition-colors rounded-full">+</button>
</div>
</div>
<div class="md:col-span-2 text-right flex items-center justify-between md:justify-end">
<span class="md:hidden text-on-surface-variant font-label-sm">Total:</span>
<span class="font-semibold text-primary">Rp 38,000</span>
<button class="hidden md:flex ml-4 p-1 text-on-surface-variant hover:text-error transition-colors">
<span class="material-symbols-outlined">close</span>
</button>
</div>
</div>
</div>
<!-- Empty State (Hidden by default) -->
<div class="hidden flex-col items-center justify-center py-24 text-center">
<div class="w-24 h-24 bg-surface-container-high rounded-full flex items-center justify-center mb-6">
<span class="material-symbols-outlined text-4xl text-on-surface-variant">shopping_basket</span>
</div>
<h2 class="font-headline-md text-on-surface mb-2">Your basket is empty</h2>
<p class="text-on-surface-variant mb-8">Looks like you haven't added any eggs to your basket yet.</p>
<a href="/products" class="bg-primary text-on-primary px-8 py-3 rounded-lg font-label-md hover:bg-on-primary-fixed-variant transition-all">Start Shopping</a>
</div>
<!-- Back to Shopping Link -->
<div class="mt-8">
<a class="inline-flex items-center text-primary font-label-md hover:underline" href="/products">
<span class="material-symbols-outlined mr-2">arrow_back</span> Continue Shopping
                    </a>
</div>
</div>
<!-- Summary Section -->
<div class="lg:col-span-4">
<div class="bg-surface-container-lowest p-6 md:p-8 rounded-2xl shadow-lg border border-surface-container-highest sticky top-24">
<h2 class="font-headline-md text-on-surface mb-6 border-b border-outline-variant pb-4">Order Summary</h2>
<div class="space-y-4 mb-6">
<div class="flex justify-between text-on-surface-variant">
<span>Subtotal</span>
<span>Rp 128,000</span>
</div>
<div class="flex justify-between text-on-surface-variant">
<span>Estimated Shipping</span>
<span class="text-primary font-medium">Free</span>
</div>
</div>
<div class="border-t border-outline-variant pt-4 mb-8">
<div class="flex justify-between items-end">
<span class="font-headline-md text-on-surface">Total</span>
<span class="font-headline-lg text-primary">Rp 128,000</span>
</div>
</div>
<!-- Checkout CTA -->
<button class="w-full bg-primary text-on-primary py-4 rounded-xl font-headline-md text-[18px] flex items-center justify-center gap-3 hover:bg-on-primary-fixed-variant shadow-md active:scale-95 transition-all duration-200">
<span class="material-symbols-outlined">chat</span>
                        Checkout via WhatsApp
                    </button>
<p class="mt-4 text-center text-label-sm text-on-surface-variant italic">Orders are processed manually via WhatsApp for a personal touch.</p>
<!-- Trust Signals -->
<div class="mt-8 pt-8 border-t border-outline-variant space-y-4">
<div class="flex items-center gap-4 group">
<div class="w-10 h-10 rounded-full bg-primary-fixed flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">verified_user</span>
</div>
<div>
<h4 class="font-label-md text-on-surface">Secure Checkout</h4>
<p class="text-[12px] text-on-surface-variant">Direct interaction with our artisan team</p>
</div>
</div>
<div class="flex items-center gap-4 group">
<div class="w-10 h-10 rounded-full bg-primary-fixed flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">clean_hands</span>
</div>
<div>
<h4 class="font-label-md text-on-surface">Hygienic Process</h4>
<p class="text-[12px] text-on-surface-variant">Cleaned and packed with medical standards</p>
</div>
</div>
</div>
</div>
</div>
</div>
</main>
<!-- Footer -->
<footer class="bg-primary text-on-primary mt-section-gap">
<div class="grid grid-cols-1 md:grid-cols-4 gap-gutter px-margin-mobile md:px-margin-desktop py-section-gap max-w-container-max mx-auto">
<div class="space-y-6">
<h2 class="font-headline-md text-headline-md font-semibold text-on-primary">Telur Asin Rose</h2>
<p class="font-body-md text-body-md text-on-primary/80">Delivering the finest artisanal salted eggs since 2024. Hand-selected, perfectly cured, and delivered with love.</p>
</div>
<div>
<h3 class="font-label-md font-bold mb-6 text-secondary-container uppercase tracking-wider">Quick Links</h3>
<ul class="space-y-4">
<li><a class="text-on-primary/80 hover:text-secondary-container transition-colors duration-200" href="/">Home</a></li>
<li><a class="text-on-primary/80 hover:text-secondary-container transition-colors duration-200" href="/products">Products</a></li>
<li><a class="text-on-primary/80 hover:text-secondary-container transition-colors duration-200" href="/about">About Our Farm</a></li>
<li><a class="text-on-primary/80 hover:text-secondary-container transition-colors duration-200" href="/products">Sustainability</a></li>
</ul>
</div>
<div>
<h3 class="font-label-md font-bold mb-6 text-secondary-container uppercase tracking-wider">Customer Care</h3>
<ul class="space-y-4">
<li><a class="text-on-primary/80 hover:text-secondary-container transition-colors duration-200" href="/faq">FAQ</a></li>
<li><a class="text-on-primary/80 hover:text-secondary-container transition-colors duration-200" href="/contact">Shipping Policy</a></li>
<li><a class="text-on-primary/80 hover:text-secondary-container transition-colors duration-200" href="/contact">Contact Us</a></li>
<li><a class="text-on-primary/80 hover:text-secondary-container transition-colors duration-200" href="/contact">Returns</a></li>
</ul>
</div>
<div>
<h3 class="font-label-md font-bold mb-6 text-secondary-container uppercase tracking-wider">Connect</h3>
<div class="flex gap-4 mb-6">
<a class="w-10 h-10 rounded-full border border-on-primary/20 flex items-center justify-center hover:bg-on-primary-fixed-variant transition-colors" href="#">
<span class="material-symbols-outlined text-[20px]">chat</span>
</a>
<a class="w-10 h-10 rounded-full border border-on-primary/20 flex items-center justify-center hover:bg-on-primary-fixed-variant transition-colors" href="#">
<span class="material-symbols-outlined text-[20px]">camera</span>
</a>
</div>
<p class="text-label-sm text-on-primary/60">© 2024 Telur Asin Rose. Made with love.</p>
</div>
</div>
</footer>
<script>
        // Simple Interaction Logic
        document.querySelectorAll('button').forEach(btn => {
            btn.addEventListener('click', function(e) {
                if (this.textContent === '+' || this.textContent === '-') {
                    const span = this.parentElement.querySelector('span');
                    let val = parseInt(span.textContent);
                    if (this.textContent === '+') span.textContent = val + 1;
                    else if (val > 1) span.textContent = val - 1;
                }
            });
        });

        // Sticky Header effect on scroll
        window.addEventListener('scroll', () => {
            const header = document.querySelector('header');
            if (window.scrollY > 20) {
                header.classList.add('shadow-md');
            } else {
                header.classList.remove('shadow-md');
            }
        });
    </script>
</body>
</html>